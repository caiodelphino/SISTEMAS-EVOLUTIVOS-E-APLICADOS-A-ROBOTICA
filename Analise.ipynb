```python
import cv2
import time
from ultralytics import YOLO
from google.colab.patches import cv2_imshow

# ==========================================
# CARREGAR IMAGEM LOCAL
# ==========================================

img = cv2.imread("/mnt/data/Captura de tela 2026-05-28 134703.png")

# ==========================================
# MODELO YOLO
# ==========================================

model = YOLO("yolo26s.pt")

# ==========================================
# INFERÊNCIA
# ==========================================

start = time.perf_counter()

results = model(
    img,
    conf=0.25,
    iou=0.45,
    imgsz=1280
)

end = time.perf_counter()

tempo = end - start

print(f"Tempo de inferência: {tempo:.4f} segundos")

# ==========================================
# CONTAGEM DE OBJETOS
# ==========================================

boxes = results[0].boxes
classes = boxes.cls.cpu().numpy()

nomes = model.names

contagem = {}

for cls in classes:
    nome = nomes[int(cls)]

    if nome in contagem:
        contagem[nome] += 1
    else:
        contagem[nome] = 1

print("\n===== OBJETOS DETECTADOS =====")

for obj, qtd in contagem.items():
    print(f"{obj}: {qtd}")

# ==========================================
# GERAR IMAGEM ANOTADA
# ==========================================

annotated = results[0].plot(
    line_width=3,
    font_size=1.2
)

# ==========================================
# MOSTRAR RESULTADO
# ==========================================

cv2_imshow(annotated)

# ==========================================
# SALVAR RESULTADO
# ==========================================

cv2.imwrite("resultado_yolo26s.png", annotated)

print("\nImagem salva como resultado_yolo26s.png")
```
